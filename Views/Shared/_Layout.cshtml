<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lis Blanc</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        /* Стили для активной вкладки */
        .navbar-nav .nav-link.active {
            font-weight: 700;
            color: #b47aff !important;
            border-bottom: 3px solid #b47aff;
            background: transparent;
        }

        .navbar-nav .nav-item .nav-link.active {
            background: transparent;
        }

        /* Для выпадающего меню пользователя */
        .navbar-nav .dropdown .nav-link.active {
            border-bottom: none;
        }

        /* Глобальные стили для адаптивности */
        .navbar-nav {
            flex-wrap: wrap;
        }

            .navbar-nav .nav-link {
                white-space: nowrap;
            }

        

        {
            white-space: normal;
            padding: 8px 12px;
        }

        .container {
            padding-left: 15px;
            padding-right: 15px;
        }

        }

        /* Чтобы контент не прилипал к краям на мобилках */
        .container {
            max-width: 100%;
            overflow-x: hidden;
        }

        /* Фикс для footer */
        html, body {
            height: 100%;
        }

        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1 0 auto;
        }

        footer {
            flex-shrink: 0;
        }

        /* ===== СТИЛИ ДЛЯ АКТИВНОЙ ВКЛАДКИ ===== */
        .navbar-nav .nav-link.active {
            font-weight: 700;
            color: #b47aff !important;
            border-bottom: 3px solid #b47aff;
            background: transparent;
        }

        .navbar-nav .nav-item .nav-link.active {
            background: transparent;
        }

        /* Для выпадающего меню пользователя */
        .navbar-nav .dropdown .nav-link.active {
            border-bottom: none;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container-fluid px-3 px-md-4">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Lis Blanc</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (!User.IsInRole("Admin") && !User.IsInRole("Manager"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewBag.ActivePage == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">Главная</a>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated)
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewBag.ActivePage == "Masters" ? "active" : "")" asp-controller="Masters" asp-action="Index">Мастера</a>
