@model IEnumerable<LisBlanc.AdminPanel.Models.User>

@{
    ViewData["Title"] = "Управление пользователями";
}

<h1>Управление пользователями</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Логин</th>
            <th>Email</th>
            <th>Роль</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.Username</td>
                <td>@user.Email</td>
                <td>
                    @switch (user.Role)
                    {
                        case "Admin":
                            <span class="badge bg-danger">Администратор</span>
                            break;
                        case "Manager":
                            <span class="badge bg-warning text-dark">Менеджер</span>
                            break;
                        default:
                            <span class="badge bg-info">Клиент</span>
                            break;
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Изменить роль</a>
                    @if (user.Role != "Admin")
                    {
                        <form asp-action="Delete" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить пользователя?')">Удалить</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>