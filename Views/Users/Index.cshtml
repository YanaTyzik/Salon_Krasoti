@model IEnumerable<LisBlanc.AdminPanel.Models.User>

@{
    ViewData["Title"] = "Управление пользователями";
}

<style>
    .user-card {
        border: none;
        border-radius: 20px;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
        margin-bottom: 20px;
        background: white;
    }

        .user-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(106, 13, 173, 0.15);
        }

        .user-card .card-header {
            background: linear-gradient(135deg, #b47aff, #8a5cd9);
            color: white;
            padding: 20px;
            text-align: center;
            border: none;
        }

    .user-avatar {
        width: 70px;
        height: 70px;
        background: rgba(255,255,255,0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

        .user-avatar i {
            font-size: 35px;
            color: white;
        }

    .user-username {
        font-size: 1.1rem;
        font-weight: 700;
        color: #2d1b4e;
        margin-top: 10px;
    }

    .role-admin {
        background: #dc3545;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .role-manager {
        background: #ffc107;
        color: #2d1b4e;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .role-client {
        background: linear-gradient(135deg, #e5d0ff, #d4b5ff);
        color: #2d1b4e;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .btn-edit {
        background: linear-gradient(135deg, #b47aff, #8a5cd9);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px 15px;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px 15px;
    }
</style>

<h1 style="color: #2d1b4e;">Управление пользователями</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    @foreach (var user in Model)
    {
        <div class="col-md-4 col-lg-3 mb-4">
            <div class="card user-card">
                <div class="card-header">
                    <div class="user-avatar">
                        <i class="fas fa-user-circle"></i>
                    </div>
                </div>
                <div class="card-body text-center">
                    <h5 class="user-username">@user.Username</h5>
                    <p class="small text-muted mb-2">@(user.Email ?? "Email не указан")</p>
                    <div class="mb-3">
                        @switch (user.Role)
                        {
                            case "Admin":
                                <span class="role-admin">Администратор</span>
                                break;
                            case "Manager":
                                <span class="role-manager">Менеджер</span>
                                break;
                            default:
                                <span class="role-client">Клиент</span>
                                break;
                        }
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3">
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-edit btn-sm flex-grow-1">
                            <i class="fas fa-edit"></i> Изменить роль
                        </a>
                        @if (user.Role != "Admin")
                        {
                            <form asp-action="Delete" method="post" style="display:inline; flex-grow:1">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn btn-delete btn-sm w-100" onclick="return confirm('Удалить пользователя?')">
                                    <i class="fas fa-trash"></i> Удалить
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">Пользователи не найдены</div>
}