@model IEnumerable<LisBlanc.AdminPanel.Models.Service>

@{
    ViewData["Title"] = "Запись онлайн - шаг 1";

    // Получаем все категории
    var categories = Model.Select(s => s.Category).Distinct().OrderBy(c => c).ToList();
    var firstCategory = categories.FirstOrDefault() ?? "";
}

<style>
    /* Стили для вкладок */
    .nav-tabs .nav-link {
        color: #495057;
        font-weight: 500;
        padding: 10px 20px;
        border: none;
        border-bottom: 3px solid transparent;
    }

        .nav-tabs .nav-link:hover {
            border-bottom-color: #dee2e6;
        }

        .nav-tabs .nav-link.active {
            color: #b47aff;
            border-bottom-color: #b47aff;
            background: none;
        }

    /* Стили для карточек услуг */
    .service-card {
        cursor: pointer;
        transition: all 0.3s;
        border: 2px solid #e5d0ff;
        border-radius: 16px;
        height: 100%;
        background: white;
        overflow: hidden;
    }

        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(180, 122, 255, 0.2);
            border-color: #b47aff;
        }

        .service-card.selected {
            border-color: #b47aff;
            background: linear-gradient(135deg, #f8f0ff, #f3e8ff);
        }

        .service-card .card-body {
            padding: 20px;
        }

        .service-card .card-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #2d1b4e;
            margin-bottom: 8px;
        }

        .service-card .price {
            font-size: 1.3rem;
            font-weight: 700;
            color: #b47aff;
        }

        .service-card .duration {
            font-size: 0.85rem;
            color: #6c757d;
            background: #f3e8ff;
            padding: 4px 10px;
            border-radius: 20px;
        }

    .category-badge {
        background: linear-gradient(135deg, #e5d0ff, #d4b5ff);
        color: #2d1b4e;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 500;
        display: inline-block;
        margin-bottom: 10px;
    }

    .progress-bar {
        background: linear-gradient(135deg, #b47aff, #8a5cd9) !important;
    }

    .btn-primary {
        background: linear-gradient(135deg, #b47aff, #8a5cd9);
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(106, 13, 173, 0.3);
        }

        .btn-primary:disabled {
            background: #c9b6e0;
            opacity: 0.6;
            transform: none;
        }
</style>

<div class="container mt-4">
    <!-- Прогресс-бар -->
    <div class="progress mb-4" style="height: 30px; border-radius: 15px;">
        <div class="progress-bar" role="progressbar" style="width: 25%; border-radius: 15px;">
            Шаг 1 из 4: Выбор услуги
        </div>
    </div>

    <h2 class="text-center mb-4" style="color: #2d1b4e;">Выберите услугу</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center" style="border-radius: 20px;">
            <i class="fas fa-spa fa-2x mb-2"></i>
            <p>Услуги временно недоступны</p>
        </div>
    }
    else
    {
        <!-- Вкладки с категориями -->
        <ul class="nav nav-tabs justify-content-center mb-4" id="categoryTabs" role="tablist">
            @foreach (var category in categories)
            {
                var isActive = category == firstCategory;
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(isActive ? "active" : "")"
                            id="tab-@category.Replace(" ", "")"
                            data-bs-toggle="tab"
                            data-bs-target="#content-@category.Replace(" ", "")"
                            type="button"
                            role="tab">
                        <i class="fas fa-tag"></i> @category
                    </button>
                </li>
            }
        </ul>

        <!-- Контент вкладок -->
        <div class="tab-content" id="categoryTabContent">
            @foreach (var category in categories)
            {
                var isActive = category == firstCategory;
                var servicesInCategory = Model.Where(s => s.Category == category).ToList();
                var categoryId = category.Replace(" ", "");

                <div class="tab-pane fade @(isActive ? "show active" : "")"
                     id="content-@categoryId"
                     role="tabpanel">

                    @if (!servicesInCategory.Any())
                    {
                        <div class="alert alert-light text-center">Нет услуг в этой категории</div>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var service in servicesInCategory)
                            {
                                <div class="col-md-6 col-lg-4 mb-4">
                                    <div class="service-card" data-service-id="@service.Id">
                                        <div class="card-body">
                                            <span class="category-badge">@service.Category</span>
                                            <h5 class="card-title">@service.Name</h5>
                                            @if (!string.IsNullOrEmpty(service.Description))
                                            {
                                                <p class="card-text text-muted small">@service.Description</p>
                                            }
                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="price">@service.Price.ToString("N0") ₽</span>
                                                <span class="duration">
                                                    <i class="far fa-clock"></i> @service.DurationMinutes мин
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Форма отправки -->
        <form asp-action="Step1" method="post" id="serviceForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="serviceId" id="selectedServiceId" value="" />

            <div id="loadingSpinner" style="display: none;" class="text-center mt-3">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Загрузка...</span>
                </div>
                <p>Проверяем доступность мастеров...</p>
            </div>

            <div class="text-center mt-4">
                <button type="button" class="btn btn-secondary btn-lg me-3" onclick="history.back()">
                    <i class="fas fa-arrow-left"></i> Назад
                </button>
                <button type="submit" class="btn btn-primary btn-lg" id="nextBtn" disabled>
                    Далее <i class="fas fa-arrow-right"></i>
                </button>
            </div>
        </form>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script>
        // Выбор услуги
        document.querySelectorAll('.service-card').forEach(card => {
            card.addEventListener('click', function() {
                // Убираем выделение со всех карточек во всех вкладках
                document.querySelectorAll('.service-card').forEach(c => {
                    c.classList.remove('selected');
                });

                // Выделяем выбранную
                this.classList.add('selected');

                // Заполняем скрытое поле
                let serviceId = this.getAttribute('data-service-id');
                document.getElementById('selectedServiceId').value = serviceId;

                // Активируем кнопку
                document.getElementById('nextBtn').disabled = false;
            });
        });

        // При переключении вкладки сбрасываем выделение
        document.querySelectorAll('[data-bs-toggle="tab"]').forEach(tab => {
            tab.addEventListener('shown.bs.tab', function() {
                document.querySelectorAll('.service-card').forEach(c => {
                    c.classList.remove('selected');
                });
                document.getElementById('selectedServiceId').value = '';
                document.getElementById('nextBtn').disabled = true;
            });
        });

        // Обработка отправки формы
        document.getElementById('serviceForm').addEventListener('submit', function() {
            if (!document.getElementById('selectedServiceId').value) {
                event.preventDefault();
                alert('Пожалуйста, выберите услугу');
                return false;
            }
            document.getElementById('loadingSpinner').style.display = 'block';
            document.getElementById('nextBtn').disabled = true;
        });
    </script>
}