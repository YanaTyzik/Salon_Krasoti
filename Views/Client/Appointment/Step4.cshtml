@model CreateAppointmentRequestViewModel

@{
    ViewData["Title"] = "Шаг 4 - контактные данные";
    var service = ViewBag.Service as Service;
}

<div class="container mt-4">
    <div class="progress mb-4" style="height: 30px;">
        <div class="progress-bar bg-primary" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
            Шаг 4 из 4: Контактные данные
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4>Введите ваши данные</h4>
                </div>
                <div class="card-body">

                    <div class="alert alert-info">
                        <h5>Вы выбрали:</h5>
                        <p><strong>Услуга:</strong> @service?.Name</p>
                        <p><strong>Дата и время:</strong> @Model.SelectedDateTime.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <input type="hidden" asp-for="MasterId" />
                        <input type="hidden" asp-for="ServiceId" />
                        <input type="hidden" asp-for="SelectedDateTime" />

                        <div class="mb-3">
                            <label asp-for="ClientName" class="form-label"></label>
                            <input asp-for="ClientName" class="form-control" placeholder="Введите ваше имя" />
                            <span asp-validation-for="ClientName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ClientPhone" class="form-label"></label>
                            <input asp-for="ClientPhone" class="form-control" />
                            <span asp-validation-for="ClientPhone" class="text-danger"></span>
                        </div>

                        <div class="text-center">
                            <a href="javascript:history.back()" class="btn btn-secondary">Назад</a>
                            <button type="submit" class="btn btn-success">Записаться</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
}