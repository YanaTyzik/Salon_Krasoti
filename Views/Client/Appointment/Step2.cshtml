@model IEnumerable<LisBlanc.AdminPanel.Models.Master>

@{
    ViewData["Title"] = "Запись онлайн - шаг 2";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int serviceId = ViewBag.ServiceId;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4>Шаг 2 из 4: Выберите мастера</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Step2" method="post">
                        <div class="row">
                            @foreach (var master in Model)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card master-card" onclick="selectMaster(@master.Id)">
                                        <div class="card-body">
                                            <h5 class="card-title">@master.FullName</h5>
                                            <p class="card-text">
                                                <strong>Специализация:</strong> @master.Specialization
                                            </p>
                                            <p class="card-text">
                                                <span class="badge bg-success">Активен</span>
                                            </p>
                                            <button type="button"
                                                    class="btn btn-outline-primary select-master"
                                                    data-master-id="@master.Id">
                                                Выбрать
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <input type="hidden" name="masterId" id="selectedMasterId" value="" />

                        <div class="text-center mt-3">
                            <a asp-action="Step1" class="btn btn-secondary">Назад</a>
                            <button type="submit" class="btn btn-primary" id="nextBtn" disabled>
                                Далее
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function selectMaster(masterId) {
            document.querySelectorAll('.master-card').forEach(c => {
                c.classList.remove('border-primary', 'border-3');
            });
            event.currentTarget.classList.add('border-primary', 'border-3');
            document.getElementById('selectedMasterId').value = masterId;
            document.getElementById('nextBtn').disabled = false;
        }

        document.querySelectorAll('.select-master').forEach(btn => {
            btn.addEventListener('click', function() {
                let masterId = this.getAttribute('data-master-id');
                document.getElementById('selectedMasterId').value = masterId;
                document.getElementById('nextBtn').disabled = false;

                document.querySelectorAll('.master-card').forEach(c => {
                    c.classList.remove('border-primary', 'border-3');
                });
                this.closest('.master-card').classList.add('border-primary', 'border-3');
            });
        });
    </script>
}
