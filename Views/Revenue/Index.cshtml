@model LisBlanc.AdminPanel.Models.RevenueViewModel

@{
    ViewData["Title"] = "Выручка";
    ViewBag.ActivePage = "Revenue";
}

<style>
    .revenue-container {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(106, 13, 173, 0.1);
    }

    .filter-card {
        background: #f8f5ff;
        border-radius: 15px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .total-card {
        background: linear-gradient(135deg, #b47aff, #8a5cd9);
        border-radius: 15px;
        padding: 20px;
        margin-bottom: 25px;
        color: white;
        text-align: center;
    }

    .total-amount {
        font-size: 2.5rem;
        font-weight: 700;
    }

    .total-label {
        font-size: 1rem;
        opacity: 0.9;
    }

    .revenue-table {
        width: 100%;
        border-collapse: collapse;
    }

        .revenue-table th {
            background: linear-gradient(135deg, #b47aff, #8a5cd9);
            color: white;
            padding: 12px;
            font-weight: 600;
        }

        .revenue-table td {
            padding: 12px;
            border-bottom: 1px solid #f0e6ff;
        }

        .revenue-table tr:hover {
            background: #faf5ff;
        }

    .btn-export {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        border-radius: 12px;
        padding: 10px 25px;
        color: white;
        transition: all 0.3s;
    }

        .btn-export:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(32, 201, 151, 0.3);
            color: white;
        }

    .filter-select, .filter-date {
        border-radius: 10px;
        border: 1px solid #e5d0ff;
        padding: 8px 15px;
    }

    .period-buttons .btn {
        border-radius: 20px;
        margin-right: 8px;
        margin-bottom: 8px;
    }

    .period-buttons .btn-active {
        background: linear-gradient(135deg, #b47aff, #8a5cd9);
        color: white;
    }
</style>

<div class="revenue-container">
    <h1 style="color: #2d1b4e; margin-bottom: 25px;">
        <i class="fas fa-chart-line" style="color: #b47aff;"></i> Выручка
    </h1>

    <!-- Карточка с общей выручкой -->
    <div class="total-card">
        <div class="total-label">Общая выручка за выбранный период</div>
        <div class="total-amount">@Model.TotalRevenue.ToString("N0") ₽</div>
        <div class="small">
            @Model.StartDate.ToString("dd.MM.yyyy") - @Model.EndDate.ToString("dd.MM.yyyy")
        </div>
    </div>

    <!-- Фильтры -->
    <div class="filter-card">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">👨‍🎨 Мастер</label>
                    <select name="masterId" class="form-select filter-select" asp-for="SelectedMasterId" onchange="this.form.submit()">
                        <option value="">— Все мастера —</option>
                        @foreach (var master in Model.Masters)
                        {
                            <option value="@master.Id" selected="@(Model.SelectedMasterId == master.Id)">
                                @master.FullName (@master.Specialization)
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-8 mb-3">
                    <label class="form-label fw-bold">📅 Период</label>
                    <div class="period-buttons">
                        <button type="submit" name="period" value="day" class="btn btn-sm @(Model.SelectedPeriod == "day" ? "btn-active" : "btn-outline-secondary")">День</button>
                        <button type="submit" name="period" value="month" class="btn btn-sm @(Model.SelectedPeriod == "month" ? "btn-active" : "btn-outline-secondary")">Месяц</button>
                        <button type="submit" name="period" value="halfyear" class="btn btn-sm @(Model.SelectedPeriod == "halfyear" ? "btn-active" : "btn-outline-secondary")">Полгода</button>
                        <button type="submit" name="period" value="year" class="btn btn-sm @(Model.SelectedPeriod == "year" ? "btn-active" : "btn-outline-secondary")">Год</button>
                        <button type="submit" name="period" value="all" class="btn btn-sm @(Model.SelectedPeriod == "all" ? "btn-active" : "btn-outline-secondary")">Всё время</button>
                    </div>
                    <input type="hidden" name="masterId" value="@Model.SelectedMasterId" />
                </div>
            </div>
        </form>

        <!-- Кнопка экспорта в Word -->
        <div class="mt-3 text-end">
            <form method="post" asp-action="ExportToWord" style="display: inline;">
                <input type="hidden" name="masterId" value="@Model.SelectedMasterId" />
                <input type="hidden" name="period" value="@Model.SelectedPeriod" />
                <button type="submit" class="btn btn-export">
                    <i class="fas fa-file-word"></i> Экспорт в Word
                </button>
            </form>
        </div>
    </div>

    <!-- Таблица с заявками -->
    <h3 style="color: #2d1b4e; margin: 20px 0 15px 0;">
        <i class="fas fa-list"></i> Выполненные записи
    </h3>

    @if (!Model.RevenueItems.Any())
    {
        <div class="alert alert-info text-center" style="border-radius: 15px;">
            <i class="fas fa-info-circle"></i> Нет подтверждённых записей за выбранный период
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="revenue-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Клиент</th>
                        <th>Телефон</th>
                        <th>Мастер</th>
                        <th>Услуга</th>
                        <th>Дата записи</th>
                        <th>Стоимость</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int counter = 1;
                        foreach (var item in Model.RevenueItems)
                        {
                            <tr>
                                <td>@counter</td>
                                <td>@item.ClientName</td>
                                <td>@item.ClientPhone</td>
                                <td>@item.MasterName</td>
                                <td>@item.ServiceName</td>
                                <td>@item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td style="color: #b47aff; font-weight: 600;">@item.Price.ToString("N0") ₽</td>
                            </tr>
                            counter++;
                        }
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="6" style="text-align: right; font-weight: 700;">Итого:</td>
                        <td style="font-weight: 700; color: #b47aff;">@Model.TotalRevenue.ToString("N0") ₽</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script>
        // Автоматическая отправка формы при изменении периода
        document.querySelectorAll('.period-buttons .btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const form = document.getElementById('filterForm');
                const periodInput = document.createElement('input');
                periodInput.type = 'hidden';
                periodInput.name = 'period';
                periodInput.value = this.value;
                form.appendChild(periodInput);
                form.submit();
            });
        });
    </script>
}