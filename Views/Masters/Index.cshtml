@model IEnumerable<LisBlanc.AdminPanel.Models.Master>

@{
    ViewData["Title"] = "Мастера";
    ViewBag.ActivePage = "Masters";
}

<style>
    .master-card {
        border: none;
        border-radius: 20px;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
        height: 100%;
        background: white;
    }

        .master-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(106, 13, 173, 0.15);
        }

        .master-card .card-header {
            background: linear-gradient(135deg, #b47aff, #8a5cd9);
            color: white;
            padding: 25px;
            text-align: center;
            border: none;
        }

    .master-avatar {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

        .master-avatar i {
            font-size: 40px;
            color: white;
        }

    .master-name {
        font-size: 1.2rem;
        font-weight: 700;
        color: #2d1b4e;
        margin-top: 15px;
        margin-bottom: 5px;
    }

    .specialization-badge {
        background: linear-gradient(135deg, #e5d0ff, #d4b5ff);
        color: #2d1b4e;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        display: inline-block;
    }

    .master-phone {
        color: #6c757d;
        font-size: 0.85rem;
    }

    .status-active {
        color: #28a745;
        font-size: 0.8rem;
    }

    .status-inactive {
        color: #6c757d;
        font-size: 0.8rem;
    }

    .btn-edit {
        background: #ffc107;
        color: #2d1b4e;
        border: none;
        border-radius: 10px;
        padding: 8px 15px;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px 15px;
    }

        .btn-edit:hover, .btn-delete:hover {
            transform: scale(1.02);
            opacity: 0.9;
        }

    .create-btn {
        background: linear-gradient(135deg, #b47aff, #8a5cd9);
        border: none;
        border-radius: 12px;
        padding: 10px 20px;
        margin-bottom: 20px;
    }

        .create-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(106, 13, 173, 0.3);
        }
</style>

<h1 style="color: #2d1b4e;">Управление специалистами</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary create-btn">
            <i class="fas fa-plus-circle"></i> Добавить нового специалиста
        </a>
    </p>
}

@if (!Model.Any())
{
    <div class="alert alert-info text-center" style="border-radius: 20px;">
        <i class="fas fa-users fa-2x mb-2"></i>
        <p>Мастера не найдены</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card master-card">
                    <div class="card-header">
                        <div class="master-avatar">
                            <i class="fas fa-user"></i>
                        </div>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="master-name">@item.FullName</h5>
                        <div class="mb-2">
                            <span class="specialization-badge">@item.Specialization</span>
                        </div>
                        <p class="master-phone mb-2">
                            <i class="fas fa-phone"></i> @item.Phone
                        </p>
                        <div class="mb-2">
                            @if (item.IsActive)
                            {
                                <span class="status-active"><i class="fas fa-circle"></i> Активен</span>
                            }
                            else
                            {
                                <span class="status-inactive"><i class="fas fa-circle"></i> Неактивен</span>
                            }
                        </div>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="card-footer bg-transparent border-0 pb-3">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-edit btn-sm">
                                    <i class="fas fa-edit"></i> Редактировать
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-delete btn-sm">
                                    <i class="fas fa-trash"></i> Удалить
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}