@model IEnumerable<LisBlanc.AdminPanel.Models.Service>

@{
    ViewData["Title"] = "Услуги";
    ViewBag.ActivePage = "Services";
}

<style>
    .service-card {
        border: none;
        border-radius: 20px;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
        height: 100%;
        background: white;
    }

        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(106, 13, 173, 0.15);
        }

        .service-card .card-header {
            background: linear-gradient(135deg, #b47aff, #8a5cd9);
            color: white;
            padding: 25px;
            text-align: center;
            border: none;
        }

    .service-icon {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

        .service-icon i {
            font-size: 40px;
            color: white;
        }

    .service-name {
        font-size: 1.2rem;
        font-weight: 700;
        color: #2d1b4e;
        margin-top: 15px;
        margin-bottom: 10px;
        word-break: break-word;
    }

    .category-badge {
        background: linear-gradient(135deg, #e5d0ff, #d4b5ff);
        color: #2d1b4e;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        display: inline-block;
    }

    .service-price {
        font-size: 1.8rem;
        font-weight: 700;
        color: #b47aff;
        margin: 10px 0;
    }

        .service-price small {
            font-size: 0.8rem;
            font-weight: normal;
            color: #6c757d;
        }

    .service-duration {
        color: #6c757d;
        font-size: 0.9rem;
    }

    .btn-edit {
        background: #ffc107;
        color: #2d1b4e;
        border: none;
        border-radius: 10px;
        padding: 8px 15px;
        transition: all 0.2s;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px 15px;
        transition: all 0.2s;
    }

    .btn-details {
        background: linear-gradient(135deg, #b47aff, #8a5cd9);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px 15px;
        transition: all 0.2s;
    }

        .btn-edit:hover, .btn-delete:hover, .btn-details:hover {
            transform: scale(1.02);
            opacity: 0.9;
        }

    .create-btn {
        background: linear-gradient(135deg, #b47aff, #8a5cd9);
        border: none;
        border-radius: 12px;
        padding: 10px 20px;
        margin-bottom: 20px;
        color: white;
        transition: all 0.2s;
    }

        .create-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(106, 13, 173, 0.3);
            color: white;
        }
</style>

<h1 style="color: #2d1b4e;">Управление услугами</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn create-btn">
            <i class="fas fa-plus-circle"></i> Добавить новую услугу
        </a>
    </p>
}

@if (!Model.Any())
{
    <div class="alert alert-info text-center" style="border-radius: 20px;">
        <i class="fas fa-concierge-bell fa-2x mb-2"></i>
        <p>Услуги не найдены</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3 mb-4">
                <div class="card service-card">
                    <div class="card-header">
                        <div class="service-icon">
                            <i class="fas fa-star"></i>
                        </div>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="service-name">@Html.DisplayFor(modelItem => item.Name)</h5>
                        <div class="mb-2">
                            <span class="category-badge">@Html.DisplayFor(modelItem => item.Category)</span>
                        </div>
                        <div class="service-price">
                            @Html.DisplayFor(modelItem => item.Price) ₽
                        </div>
                        <div class="service-duration">
                            <i class="fas fa-clock"></i> @Html.DisplayFor(modelItem => item.DurationMinutes) минут
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <div class="d-flex gap-2 justify-content-center flex-wrap">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-edit btn-sm">
                                    <i class="fas fa-edit"></i> Редактировать
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-delete btn-sm">
                                    <i class="fas fa-trash"></i> Удалить
                                </a>
                            }
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-details btn-sm">
                                <i class="fas fa-eye"></i> Просмотр
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}